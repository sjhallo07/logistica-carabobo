# Example environment variables (do NOT commit real secrets)
IG_ACCESS_TOKEN=
IG_BUSINESS_ID=
IG_API_VERSION=v17.0
SUPABASE_URL=https://picfkguawkzhbdvagcbi.supabase.co
SUPABASE_KEY=
GITHUB_PAT=
HF_TOKEN=h
# Database connection (for scripts that connect directly to Postgres/Supabase)
# Copy this into a local .env and replace [YOUR-PASSWORD]
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.picfkguawkzhbdvagcbi.supabase.co:5432/postgres

# Optional: override the MCP endpoint (Model Context Protocol) used by the app.
# If not set, the app will attempt to derive the MCP proxy URL from SUPABASE_URL.
# Example (points to Supabase MCP proxy):
# MCP_BASE_URL=https://mcp.supabase.com/mcp?project_ref=picfkguawkzhbdvagcbi&features=docs%2Caccount%2Cdatabase%2Cdebugging%2Cdevelopment%2Cfunctions%2Cbranching%2Cstorage

# Supabase Data API base URL (used as fallback for REST inserts)
# Example: https://picfkguawkzhbdvagcbi.supabase.co
SUPABASE_API_URL=https://picfkguawkzhbdvagcbi.supabase.co

# Local MCP server port used when not overriding MCP_BASE_URL. Default: 9000
# Example: MCP_PORT=9000
MCP_PORT=9000

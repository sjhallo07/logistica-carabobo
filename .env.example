# Example environment variables (do NOT commit real secrets)

# -- Authentication tokens --
# GitHub / GitHub Models
GITHUB_API_TOKEN=
GITHUB_TOKEN=

# Hugging Face
HF_TOKEN=

# Docker registry credentials (used by CI or manual docker login)
# For example, to login in a script: echo "$DOCKER_PAT" | docker login -u "$DOCKER_USERNAME" --password-stdin
DOCKER_USERNAME=
DOCKER_PAT=

# -- Supabase (optional) --
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_API_URL=https://<your-project-ref>.supabase.co
SUPABASE_KEY=

# -- Instagram Graph API (optional) --
IG_ACCESS_TOKEN=
IG_BUSINESS_ID=
IG_API_VERSION=v17.0

# Database connection (for scripts that connect directly to Postgres/Supabase)
# Example: DATABASE_URL=postgresql://postgres:yourpassword@db.<project>.supabase.co:5432/postgres
DATABASE_URL=

# MCP configuration
# If you deploy the app to a remote MCP / MCP proxy, set MCP_BASE_URL accordingly.
# Example (Supabase MCP proxy):
# MCP_BASE_URL=https://mcp.supabase.com/mcp?project_ref=<your-ref>&features=docs%2Caccount%2Cdatabase%2Cdebugging%2Cdevelopment%2Cfunctions%2Cbranching%2Cstorage
MCP_BASE_URL=
MCP_PORT=9000

# Allowed models (comma-separated). Leave empty to allow all locally available models.
ALLOWED_MODELS=

# Notes:
# - Copy this file to `.env` and populate the real secrets before running locally.
# - Do NOT commit your real `.env` to the repository.
